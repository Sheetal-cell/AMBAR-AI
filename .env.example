# .env.example
# === Satellite APIs ===
COPERNICUS_USER=your_cdse_email
COPERNICUS_PASS=your_cdse_password
CDSE_CLIENT_ID=your_client_id
CDSE_CLIENT_SECRET=your_client_secret

# === ERA5 (Copernicus CDS) ===
CDS_URL=https://cds.climate.copernicus.eu/api
CDS_KEY=your-uid:your-api-key

# === FIRMS (NASA) ===
FIRMS_MAP_KEY=your_firms_map_key  # free from firms.modaps.eosdis.nasa.gov

# === MOSDAC (ISRO) ===
MOSDAC_USER=your_mosdac_user
MOSDAC_PASS=your_mosdac_password

# === CPCB ===
CPCB_API_KEY=your_cpcb_api_key   # from api.cpcb.gov.in

# === Database ===
DATABASE_URL=postgresql://ambar:secret@postgres:5432/ambar_db

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === App ===
SECRET_KEY=change_this_in_production
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token